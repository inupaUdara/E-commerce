{
  "info": {
    "name": "GoCart Microservices",
    "description": "Complete API collection for testing inter-service communication",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. User Service",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "pm.environment.set(\"userId\", response.userId);",
                  "pm.environment.set(\"token\", response.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"SELLER\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "pm.environment.set(\"token\", response.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/auth/authenticate",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "auth", "authenticate"]
            }
          }
        },
        {
          "name": "Create Address",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "pm.environment.set(\"addressId\", response.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"street\": \"123 Main St\",\n  \"city\": \"Colombo\",\n  \"state\": \"Western\",\n  \"zip\": \"10000\",\n  \"country\": \"Sri Lanka\",\n  \"phone\": \"+94771234567\",\n  \"userId\": \"{{userId}}\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/addresses",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "addresses"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Store Service",
      "item": [
        {
          "name": "Create Store (validates User)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "pm.environment.set(\"storeId\", response.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tech Store\",\n  \"address\": \"456 Commerce Ave\",\n  \"city\": \"Colombo\",\n  \"state\": \"Western\",\n  \"zip\": \"10100\",\n  \"phone\": \"+94771234567\",\n  \"userId\": \"{{userId}}\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/stores",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "stores"]
            },
            "description": "This request demonstrates inter-service communication:\n→ Store Service calls User Service to validate user exists"
          }
        }
      ]
    },
    {
      "name": "3. Product Service",
      "item": [
        {
          "name": "Create Product (validates Store)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "pm.environment.set(\"productId\", response.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Laptop\",\n  \"description\": \"High-performance laptop\",\n  \"mrp\": 1500.00,\n  \"price\": 1299.99,\n  \"images\": [\"laptop1.jpg\", \"laptop2.jpg\"],\n  \"category\": \"Electronics\",\n  \"inStock\": true,\n  \"storeId\": \"{{storeId}}\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/products",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "products"]
            },
            "description": "This request demonstrates inter-service communication:\n→ Product Service calls Store Service to validate store exists"
          }
        }
      ]
    },
    {
      "name": "4. Order Service",
      "item": [
        {
          "name": "Create Coupon",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"SAVE10\",\n  \"description\": \"10% discount\",\n  \"discount\": 10.0,\n  \"forNewUser\": false,\n  \"forMember\": true,\n  \"isPublic\": true,\n  \"expiresAt\": \"2025-12-31T23:59:59\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/coupons",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "coupons"]
            }
          }
        },
        {
          "name": "Create Order (validates User, Store, Product)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"storeId\": \"{{storeId}}\",\n  \"addressId\": \"{{addressId}}\",\n  \"paymentMethod\": \"COD\",\n  \"couponCode\": \"SAVE10\",\n  \"items\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"quantity\": 1,\n      \"price\": 1299.99\n    }\n  ]\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/orders",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "orders"]
            },
            "description": "This request demonstrates ALL inter-service communications:\n→ Order Service calls User Service to validate user\n→ Order Service calls User Service to validate address\n→ Order Service calls Store Service to validate store\n→ Order Service calls Product Service to validate product and stock"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "addressId",
      "value": ""
    },
    {
      "key": "storeId",
      "value": ""
    },
    {
      "key": "productId",
      "value": ""
    }
  ]
}
